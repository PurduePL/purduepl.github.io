{
  "ci": {
    "collect": {
      "staticDistDir": "./_site",
      "numberOfRuns": 3,
      "url": [
        "/index.html",
        "/seminars.html",
        "/research.html",
        "/courses.html"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "categories:accessibility": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "categories:seo": ["error", { "minScore": 0.95, "aggregationMethod": "median" }]
      }
    }
  }
}
